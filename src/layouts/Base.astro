---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CABS · AI & Digital Productivity Series',
  description = 'The CABS AI & Digital Productivity Series — talks, speakers, and an open knowledge hub for AI, digital productivity, and life-science professionals.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="bg-fx" aria-hidden="true"></div>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href="/">CABS <span>AI &amp; Digital Productivity</span> Series</a>
        <nav class="nav">
          <a href="/#talks">Talks</a>
          <a href="/submit">Propose a talk</a>
          <a href="https://ds4cabs.github.io/" target="_blank" rel="noopener">Summer Intern Program</a>
          <a class="nav-icon" href="https://github.com/ds4cabs" target="_blank" rel="noopener" aria-label="CABS on GitHub" title="CABS on GitHub">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.2 3.44 9.6 8.21 11.16.6.11.82-.25.82-.56 0-.28-.01-1.02-.02-2-3.34.71-4.04-1.58-4.04-1.58-.55-1.37-1.34-1.74-1.34-1.74-1.09-.73.08-.72.08-.72 1.2.08 1.84 1.21 1.84 1.21 1.07 1.79 2.81 1.27 3.49.97.11-.76.42-1.27.76-1.56-2.67-.3-5.47-1.31-5.47-5.81 0-1.28.47-2.33 1.24-3.15-.13-.3-.54-1.51.12-3.15 0 0 1.01-.32 3.3 1.2.96-.26 1.98-.39 3-.4 1.02.01 2.04.14 3 .4 2.28-1.52 3.29-1.2 3.29-1.2.66 1.64.25 2.85.12 3.15.77.82 1.24 1.87 1.24 3.15 0 4.51-2.81 5.5-5.49 5.79.43.36.81 1.09.81 2.19 0 1.58-.01 2.86-.01 3.25 0 .31.21.68.83.56C20.57 21.88 24 17.48 24 12.29 24 5.78 18.63.5 12 .5z"/></svg>
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        CABS AI &amp; Digital Productivity Series · A community knowledge hub for AI,
        digital productivity, and life-science professionals.
      </div>
    </footer>
  </body>
</html>
