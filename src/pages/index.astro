---
import Base from '../layouts/Base.astro';
import SessionCard from '../components/SessionCard.astro';
import { getSessions } from '../lib/db.ts';

// One combined list of every public talk — upcoming first (soonest first),
// then past talks (most recent first).
const all = await getSessions({ status: ['scheduled', 'published', 'archived'] });
const now = Date.now();
const upcoming = all
  .filter((s) => new Date(s.date).getTime() >= now)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
const past = all
  .filter((s) => new Date(s.date).getTime() < now)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const talks = [...upcoming, ...past];
---

<Base>
  <section class="hero">
    <span class="eyebrow"><span class="dot"></span> AI &amp; Digital Productivity</span>
    <h1>Where the community learns <span class="grad">what actually works</span> in AI.</h1>
    <p>
      A speaker series and open knowledge hub. Every talk is recorded,
      summarized, and archived — so the whole community keeps learning long
      after each session ends.
    </p>
    <div class="hero-actions">
      <a class="btn" href="/submit">Propose a talk →</a>
      {talks.length > 0 && <a class="btn secondary" href="#talks">Browse talks</a>}
    </div>
  </section>

  <section id="talks" class="section container">
    <h2>Talks &amp; speakers</h2>
    <p class="section-lead">
      {upcoming.length} upcoming · {past.length} in the archive — all in one place.
    </p>
    {talks.length === 0 ? (
      <p class="empty">No talks yet — <a href="/submit">be the first to propose one</a>.</p>
    ) : (
      <div class="talk-grid">
        {talks.map((s) => <SessionCard session={s} />)}
      </div>
    )}
  </section>
</Base>
