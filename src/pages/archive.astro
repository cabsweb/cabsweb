---
import Base from '../layouts/Base.astro';
import SessionCard from '../components/SessionCard.astro';
import { getArchive } from '../lib/db.ts';

const archived = await getArchive();

// Build a tag index so members can filter the knowledge hub by topic.
const tagCounts = new Map<string, number>();
for (const s of archived) for (const t of s.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Archive · CABS AI & Digital Productivity Series">
  <section class="section container" style="padding-top:2.5rem;">
    <h2>Knowledge hub archive</h2>
    <p class="section-lead">
      Every past session, with its recording, slides, transcript, and an
      AI-generated summary so you can find the takeaways in seconds.
    </p>

    {tags.length > 0 && (
      <div class="tags" style="margin-bottom:1.5rem;">
        {tags.map(([t, n]) => <span class="tag">{t} · {n}</span>)}
      </div>
    )}

    {archived.length === 0 ? (
      <p class="empty">The archive is empty for now. Past talks appear here once they are recorded and summarized.</p>
    ) : (
      <div class="grid">
        {archived.map((s) => <SessionCard session={s} />)}
      </div>
    )}
  </section>
</Base>
