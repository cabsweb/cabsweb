---
import type { Session } from '../lib/types.ts';
import { formatDateLong } from '../lib/format.ts';
import { speakerSlug } from '../lib/db.ts';

interface Props {
  session: Session;
}
const { session } = Astro.props;
const speakerHref = `/speakers/${speakerSlug(session.speaker.name)}`;
const isArchived = session.status === 'archived';
const label = isArchived ? 'Archived' : 'Upcoming';
const badgeClass = isArchived ? 'archived' : 'published';
---

<article class="card talk-card">
  <img class="talk-photo" src={session.speaker.photo} alt={session.speaker.name} onerror="this.onerror=null;this.src='/speakers/placeholder.svg'" />
  <div class="talk-info">
    <div class="talk-top">
      <span class="meta">{formatDateLong(session.date)}</span>
      <span class={`badge ${badgeClass}`}>{label}</span>
    </div>
    <h3><a href={`/events/${session.slug}`}>{session.title}</a></h3>
    <div class="talk-speaker">
      <a href={speakerHref}><strong>{session.speaker.name}</strong></a>
      {session.speaker.org && <span class="meta"> · {session.speaker.org}</span>}
    </div>
    {session.tags.length > 0 && (
      <div class="tags">
        {session.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
  </div>
</article>
